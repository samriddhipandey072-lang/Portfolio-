      .profile-frame { width:100%; max-width:420px; }
      .service-grid { grid-template-columns: repeat(2,1fr); }
      .timeline .wrap { flex-direction:column; }
      .timeline .line-column { display:none; }
    }
    @media (max-width:600px) {
      .headline .big-gradient { font-size:44px; }
      .service-grid { grid-template-columns: 1fr; }
      .nav-links { gap:18px; }
      .logo { margin-left: 0; }
    }
  </style>
