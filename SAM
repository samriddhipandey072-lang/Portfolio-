      display:flex; justify-content:center; margin-top:36px;
    }
    .see-more .btn {
      background:#2563eb; color:white; padding:16px 36px; border-radius:14px; font-weight:700; box-shadow: 0 12px 30px rgba(37,99,235,0.15);
    }

    /* ---------- TIMELINE / ACADEMIC ---------- */
    section.timeline { padding:80px 0; background:white; }
    .timeline h2 { text-align:center; font-size:44px; font-weight:800; margin-bottom:22px; }
    .timeline .wrap { display:flex; gap:40px; align-items:flex-start; margin-top:20px; }
    .timeline .line-column { width:90px; display:flex; justify-content:center; position:relative; }
    .timeline .vertical {
      width:3px; background:linear-gradient(180deg,#e6edf9,#f2f4f8); height:830px; border-radius:4px; position:relative;
    }
    .dot { width:10px; height:10px; background:#2563eb; border-radius:50%; position:absolute; left:50%; transform:translateX(-50%); top:6px; }

    .edu-cards { flex:1; }
    .edu-card { background:white; padding:28px; border-radius:12px; box-shadow:0 10px 30px rgba(15,23,36,0.04); margin-bottom:28px; }

    /* ---------- PROJECTS (optional scaffold so the nav link works) ---------- */
    section.projects { padding:60px 0; background:#f3f5f8; text-align:center; }
    .projects .heading { font-size:44px; font-weight:800; margin-bottom:8px; }
    .projects .sub { color:#6b7280; margin-bottom:28px; }
    .proj-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:28px; max-width:1200px; margin:0 auto; }
    .proj-card { background:white; border-radius:16px; overflow:hidden; box-shadow:0 10px 30px rgba(15,23,36,0.04); text-align:left; }
    .proj-card img { width:100%; height:180px; object-fit:cover; display:block; }
    .proj-body { padding:20px; }
    .proj-body h4 { font-weight:700; margin-bottom:10px; }
    .proj-tags { margin-top:12px; display:flex; gap:8px; flex-wrap:wrap; }
    .tag { background:#eef2ff; color:#2563eb; padding:6px 10px; border-radius:999px; font-weight:600; font-size:13px; }

    .view-all-btn { margin-top:28px; text-align:center; }
    .view-all-btn .btn { background:#2563eb; color:white; padding:16px 32px; border-radius:16px; font-weight:700; box-shadow:0 12px 30px rgba(37,99,235,0.15); }

    /* ---------- CTA / CONTACT ---------- */
    .cta {
      background: linear-gradient(90deg,#2e6bff 0%, #8b46ff 100%);
      color:white; padding:64px 0; text-align:center; margin-top:40px;
    }
    .cta h2 { font-size:44px; font-weight:800; margin-bottom:10px; }
    .cta p { max-width:900px; margin:0 auto 24px; color:rgba(255,255,255,0.85); }
    .cta .cta-btn { background:transparent; border:2px solid rgba(255,255,255,0.18); color:white; padding:12px 28px; border-radius:14px; font-weight:700; margin:8px; display:inline-block; text-decoration:none; }

    /* ---------- footer ---------- */
    footer { text-align:center; padding:18px 0; color:#94a3b8; }

    /* ---------- Responsive adjustments ---------- */
    @media (max-width:1200px) {
      .headline .big-gradient { font-size:56px; }
    }
    @media (max-width:992px) {
      .hero { flex-direction:column; }
