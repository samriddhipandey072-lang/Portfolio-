  <style>
    /* ---------- Reset & base ---------- */
    * { box-sizing: border-box; }
    html,body { height:100%; }
    body {
      margin: 0;
      font-family: 'Poppins', sans-serif;
      background: linear-gradient(90deg,#fbfdff 0%, #f5f7fb 100%);
      color: #1f2937;
      overflow-y: scroll;
    }
    img { max-width: 100%; display:block; }

    .container { max-width: 1320px; width: 92%; margin: 0 auto; }

    /* ---------- NAV ---------- */
    header {
      background: rgba(255,255,255,0.9);
      position: sticky;
      top: 0;
      z-index: 50;
      border-bottom: 1px solid rgba(0,0,0,0.04);
      backdrop-filter: saturate(180%) blur(8px);
    }
    .nav { height:72px; display:flex; align-items:center; justify-content:space-between; }
    .logo { color:#2370ff; font-weight:800; font-size:22px; margin-left: 12px; }
    .nav-links { display:flex; gap:34px; align-items:center; font-weight:500; color:#111827; margin-right: 12px; }
    .nav-links a { color:#111827; text-decoration:none; }
    .nav-links a:hover { color:#2563eb; }
    .contact-btn { background: #2370ff; color:white; padding:10px 18px; border-radius:12px; box-shadow: 0 6px 20px rgba(35,112,255,0.15); text-decoration:none; }

    /* ---------- HERO ---------- */
    .hero { display:flex; align-items:center; gap:40px; padding:64px 0; }
    .hero-left { width:58%; padding-left:24px; }
    .hello-bubble {
      display:inline-flex; align-items:center; gap:8px; padding:10px 16px; background:#eef4ff; color:#2563eb; border-radius:18px; font-weight:600; width:max-content;
      box-shadow: 0 2px 0 rgba(37,99,235,0.05);
    }

    .headline {
      margin-top:26px;
      font-weight:800;
      line-height:0.95;
      color:#0f1724;
    }
    .headline .name { color:#2563eb; }
    .headline .big-gradient {
      display:block;
      font-size:68px;
      /* gradient text like template */
      background: linear-gradient(90deg,#2563eb,#8b46ff);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
    }

    .subtext { margin-top:20px; color:#667085; font-size:16px; max-width:560px; }

    .hero-cta { margin-top:28px; display:flex; gap:16px; align-items:center; }
    .btn-primary {
      background: linear-gradient(90deg,#246BFF 0%, #8C47FF 100%);
      color:white; padding:14px 28px; border-radius:14px; font-weight:700; box-shadow: 0 10px 30px rgba(36,107,255,0.15);
      text-decoration:none;
    }
    .btn-outline {
      background:white; border:2px solid rgba(36,107,255,0.12); color:#2563eb; padding:12px 26px; border-radius:12px; font-weight:600; text-decoration:none;
    }

    /* ---------- hero right card (profile picture) ---------- */
    .hero-right { width:42%; display:flex; justify-content:center; position:relative; }
    .profile-frame {
      width:420px; padding:26px; border-radius:28px; background:white; position:relative;
      box-shadow: 0 40px 60px rgba(140,71,255,0.06), 0 20px 40px rgba(36,107,255,0.06);
      overflow:visible;
    }
    .outer-glow {
      position:absolute; inset:-14px; border-radius:34px; filter: blur(36px); pointer-events:none;
      background: linear-gradient(180deg, rgba(36,107,255,0.06), rgba(140,71,255,0.08));
      z-index:-2;
    }
    .tag-top {
      position:absolute; right:34px; top:-12px; background:#2563eb; color:white; padding:8px 14px; border-radius:18px; font-weight:700; font-size:14px;
    }
    .photo-wrap { border-radius:20px; overflow:hidden; background:#f3f6ff; }
    .photo-wrap img { width:100%; height:380px; object-fit:cover; display:block; border-radius:14px; }

    .tag-bottom {
      position:absolute; left:18px; bottom:-18px; background:linear-gradient(90deg,#8C47FF,#6E56FF); color:white; padding:8px 14px; border-radius:18px; font-weight:700;
      font-size:13px;
      box-shadow: 0 12px 30px rgba(140,71,255,0.12);
    }

    /* ---------- SERVICES ---------- */
    section.services { padding:60px 0; background:#f3f5f8; }
    .services .heading { text-align:center; margin-bottom:18px; font-size:40px; font-weight:800; }
    .services .sub { text-align:center; color:#6b7280; margin-bottom:36px; }
    .service-grid { display:grid; grid-template-columns:repeat(4,1fr); gap:28px; }
    .service-card {
      background:white; border-radius:16px; padding:30px; box-shadow: 0 6px 20px rgba(15,23,36,0.04);
    }
    .service-card h3 { font-size:20px; margin-top:10px; margin-bottom:12px; font-weight:700; }
    .service-card p { color:#6b7280; line-height:1.6; }

